# LLM provider (LiteLLM format: "gpt-4.1-mini", "deepseek/deepseek-chat", "gemini/gemini-2.5-flash")
AWESCHOLAR_MODEL=gpt-4.1-mini
AWESCHOLAR_API_KEY=your-llm-api-key
# AWESCHOLAR_BASE_URL=https://your-custom-endpoint.com/v1

# Semantic Scholar (optional, public tier works without key)
SEMANTICSCHOLAR_API_KEY=

# Default output directory
AWESCHOLAR_DB_PATH=output
